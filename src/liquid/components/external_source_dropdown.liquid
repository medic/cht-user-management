<div class="dropdown is-hoverable ml-5">
  <div class="dropdown-trigger">
    <button class="button is-link" aria-haspopup="true" aria-controls="external-registry-menu" type="button">
      <span>Use external source</span>
      <span class="icon is-small">
        <span class="material-symbols-outlined">expand_more</span>
      </span>
    </button>
  </div>
  <div class="dropdown-menu" id="external-registry-menu" role="menu">
    <div class="dropdown-content">
      {% for externalSource in externalSources %}
        <a href="/add-from-external-source?source_id={{ externalSource.id }}&type={{ contactType.name }}" class="dropdown-item">
          {{ externalSource.friendly_name }}
        </a>
      {% endfor %}
    </div>
  </div>
</div>
